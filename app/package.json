{
  "name": "bitcord-app",
  "private": true,
  "version": "0.1.0",
  "description": "Tauri/React frontend for the BitCord encrypted P2P communication platform",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitcord-net/BitCord"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node scripts/tauri-dev.mjs",
    "tauri:build": "node scripts/tauri-build.mjs",
    "tauri:icon": "cd ../crates/bitcord-tauri && node ../../app/node_modules/@tauri-apps/cli/tauri.js icon icons/app-icon.png",
    "tauri:android:init": "cd ../crates/bitcord-tauri && node ../../app/node_modules/@tauri-apps/cli/tauri.js android init",
    "tauri:android:dev": "node scripts/tauri-android-dev.mjs",
    "tauri:android:build": "cd ../crates/bitcord-tauri && node ../../app/node_modules/@tauri-apps/cli/tauri.js android build"
  },
  "dependencies": {
    "@automerge/automerge": "^3",
    "@tanstack/react-query": "^5",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^7",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4",
    "zustand": "^5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "eslint-plugin-react-refresh": "^0.4",
    "typescript": "^5",
    "vite": "^6"
  }
}
